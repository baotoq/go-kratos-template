# Per-developer dev container environment.
#
# Copy this file to `.env` and fill in your local values:
#   cp .devcontainer/.env.example .devcontainer/.env
#
# `.devcontainer/.env` is gitignored. Loaded into the container via `runArgs:
# --env-file` in devcontainer.json, so changes require a container rebuild.

# --- Kubernetes ---------------------------------------------------------------

# Override hostname kubeconfig is rewritten to. Auto-detected if unset:
#   OrbStack       → k8s.orb.local
#   Docker Desktop → host.docker.internal
KUBE_HOST_REWRITE=k8s.orb.local

# Kill-switch for the host→container kubeconfig sync. Defaults to "true";
# set to "false" only if you don't want ~/.kube/config managed by the container.
SYNC_LOCALHOST_KUBECONFIG=false

# --- Secrets / API keys -------------------------------------------------------

# GITHUB_TOKEN=
